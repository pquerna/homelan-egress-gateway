[Unit]
Description=Egress Gateway DNS Resolver
After=network-online.target
Wants=network-online.target

[Container]
Image=localhost/egress-unbound:local
ContainerName=egress-unbound

PublishPort=192.168.32.100:53:53/tcp
PublishPort=192.168.32.100:53:53/udp

ReadOnly=true
DropCapability=all
AddCapability=NET_BIND_SERVICE
NoNewPrivileges=true

[Service]
Restart=always
RestartSec=2s

[Install]
WantedBy=multi-user.target
